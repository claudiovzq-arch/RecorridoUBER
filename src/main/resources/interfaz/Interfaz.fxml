<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>


<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="interfaz.Controlador">
   <top>
      <GridPane BorderPane.alignment="CENTER">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Button fx:id="btnGenUsuario" mnemonicParsing="false" onAction="#generarUsuario" text="Generar usuario" GridPane.halignment="CENTER" GridPane.valignment="CENTER" />
            <Button fx:id="btnGenChofer" mnemonicParsing="false" onAction="#generarChofer" text="Generar Chofer" GridPane.halignment="CENTER" GridPane.rowIndex="1" GridPane.valignment="CENTER" />
            <Button fx:id="btnSimular" mnemonicParsing="false" onAction="#simularViaje" text="Simular" GridPane.halignment="CENTER" GridPane.rowIndex="2" GridPane.valignment="CENTER" />
         </children>
      </GridPane>
   </top>
   <center>
      <VBox prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="lblUsuario" text="Label" />
            <ListView fx:id="listaChoferes" prefHeight="200.0" prefWidth="200.0" />
         </children>
      </VBox>
   </center>
   <bottom>
      <Pane prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <Circle fx:id="auto" fill="#2fff00" layoutX="30.0" layoutY="50.0" radius="16.0" stroke="BLACK" strokeType="INSIDE" />
            <Circle fx:id="destino" fill="DODGERBLUE" layoutX="570.0" layoutY="50.0" radius="16.0" stroke="BLACK" strokeType="INSIDE" />
         </children>
      </Pane>
   </bottom>
</BorderPane>
